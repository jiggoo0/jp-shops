{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["**/*.{ts,tsx}"],
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "actions/**/*.ts",
    "lib/auth.ts",
    "lib/index.ts",
    "lib/bot/strategies/*.ts"
  ],
  "ignore": ["types/**"],
  "ignoreDependencies": ["eslint-config-next", "postcss-load-config"],
  "ignoreExportsUsedInFile": true
}
