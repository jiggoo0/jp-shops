{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["**/*.{ts,tsx}"],
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "actions/**/*.ts",
    "lib/auth.ts",
    "lib/index.ts",
    "middleware.ts",
    "next.config.ts"
  ],
  "ignore": [
    "node_modules/**",
    ".next/**",
    "supabase/migrations/**",
    "types/**"
  ],

  "ignoreDependencies": [
    "sharp",
    "unrs-resolver",
    "eslint-config-next",
    "postcss-load-config"
  ],
  "ignoreBinaries": ["next", "prettier", "eslint", "knip", "tsc"],
  "ignoreExportsUsedInFile": true
}
