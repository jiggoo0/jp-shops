{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["**/*.{ts,tsx}"],
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "config/**/*.{ts,tsx}",
    "constants/**/*.{ts,tsx}",
    "scripts/**/*.mjs"
  ],
  "ignore": ["mdx-components.tsx"],
  "ignoreDependencies": [
    "eslint-config-next",
    "postcss",
    "autoprefixer",
    "eslint",
    "prettier-plugin-tailwindcss",
    "postcss-load-config"
  ],
  "ignoreExportsUsedInFile": true
}
